# MinIO credentials (copy MINIO_ACCESS_KEY / MINIO_SECRET_KEY from minio/.env)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MinIO S3-compatible endpoint
MLFLOW_S3_ENDPOINT_URL=https://s3.ops4life.com

# MinIO path for MLflow artifact storage
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow/artifacts

# PostgreSQL password for MLflow backend store (production stack)
DB_PASSWORD=change_me
